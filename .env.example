# Example environment variables. Copy to .env.local for local development and
# set the real values in Vercel for production. Do NOT commit real secrets —
# only .env.example is tracked (see .gitignore).

# Microsoft Clarity project id (public, non-secret). Powers the analytics tag
# in the root layout. When unset, the Clarity tag is not rendered.
NEXT_PUBLIC_CLARITY_ID=xnso4f5y2k

# Google Analytics 4 measurement id (public, non-secret). Loaded by
# components/analytics/GoogleAnalytics.tsx via next/script once the visitor
# grants analytics consent; drives the view_item → open_constructor →
# upload_photo → begin_checkout → purchase funnel. When unset, GA is not
# rendered. (NEXT_PUBLIC_GA_MEASUREMENT is an accepted legacy alias.)
NEXT_PUBLIC_GA_ID=G-DKJRQZ5FYW
