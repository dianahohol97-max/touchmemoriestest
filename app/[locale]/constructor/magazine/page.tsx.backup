      { content: 'Про вас', x:55, y:3, width:42, fontSize:8, fontFamily:'Montserrat', color:'#ffffff', isPreset:true, align: 'right' },
      { content: "ІМ'Я", x:10, y:62, width:80, fontSize:64, fontFamily:'Playfair Display', color:'#ffffff', align:'center', italic:false, isPreset:true },
