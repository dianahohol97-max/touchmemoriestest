      { content: 'Only you', x:20, y:72, width:60, fontSize:22, fontFamily:'Dancing Script', color:'#ffffff', align:'center', isPreset:true },
    ]
  },
  'cover-split': {
    type: 'cover', label: 'Розділена обкладинка', slots: [{ x:0, y:0, w:55, h:100 }],
    defaultTextBlocks: [
      { content: "ІМ'Я", x:58, y:30, width:40, fontSize:48, fontFamily:'Playfair Display', color:'#1a1a1a', align:'center', isPreset:true },
      { content: 'FASHION MAGAZINE', x:58, y:55, width:40, fontSize:9, fontFamily:'Montserrat', color:'#666666', align:'center', letterSpacing:4, isPreset:true },
    ]
  },
  'layout-full-bleed': { type: 'photo', label: 'На весь розворот', slots: [{ x:0, y:0, w:100, h:100 }] },
